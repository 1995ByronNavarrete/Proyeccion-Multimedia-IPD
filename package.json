{
  "name": "desktopappipd",
  "version": "1.3.6",
  "description": "Sistema de proyección multimedia profesional para iglesias",
  "author": "Byron Antonio Navarrete Cañada",
  "main": "./out/main/index.js",
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('./out',{recursive:true,force:true})\"",
    "dev": "npm run clean && electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "release": "npm run typecheck && electron-vite build && electron-builder --win --publish always"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "lucide-react": "^0.487.0",
    "mammoth": "^1.12.0",
    "pdfjs-dist": "^2.16.105",
    "play-dl": "^1.9.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "sql.js": "^1.11.0",
    "youtube-dl-exec": "^3.1.6",
    "yt-search": "^2.13.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/sql.js": "^1.4.9",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "postcss": "^8.5.2",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vite": "^5.4.11"
  },
  "build": {
    "appId": "com.ipd.desktopappipd",
    "productName": "Proyección Multimedia IPD",
    "directories": {
      "output": "release"
    },
    "publish": {
      "provider": "github",
      "owner": "1995ByronNavarrete",
      "repo": "Proyeccion-Multimedia-IPD",
      "releaseType": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "resources/icon.png",
      "signingHashAlgorithms": null,
      "sign": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "extraResources": [
      {
        "from": "resources/DesktopAppIPD",
        "to": "DesktopAppIPD"
      },
      {
        "from": "resources/bible-data.db",
        "to": "bible-data.db"
      },
      {
        "from": "resources/bundled-data.db",
        "to": "bundled-data.db"
      }
    ]
  }
}
